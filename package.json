{
  "name": "minecraft-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts --",
    "start": "bun run src/index.ts --",
    "local": "bash scripts/run-local.sh",
    "mem": "bash scripts/watch-memory.sh",
    "check-types": "tsc --noEmit",
    "tests": "bun run tests/test-connection.ts",
    "build": "bun scripts/build.ts",
    "build:win": "bun scripts/build.ts win",
    "build:linux": "bun scripts/build.ts linux",
    "build:mac": "bun scripts/build.ts mac",
    "build:all": "bun scripts/build.ts all"
  },
  "dependencies": {
    "ai": "^6.0.6",
    "gambi-sdk": "0.6.0",
    "jsonrepair": "^3.12.0",
    "mineflayer": "^4.23.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "mineflayer-tool": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
