# ─── Gambiarra Hub ─────────────────────────────────────────
# URL do hub Gambiarra (defaults para CLI --hub e env fallback)
# GAMBIARRA_HUB_URL=http://localhost:3000

# Modelo preferido (default para CLI --model, "*" usa qualquer)
# GAMBIARRA_MODEL=*

# Nota: o room code é passado via CLI, não aqui.
#   bun run start -- --room ABC123

# ─── Admin de chat ────────────────────────────────────────
# Nicks (separados por vírgula) que comandam os bots pelo chat.
# Vazio: qualquer jogador não-bot comanda (só pra dev local).
CHAT_ADMINS=jvras58

# ─── Agente / LLM ─────────────────────────────────────────
# Limite de tokens gerados por ciclo. Aumente se o modelo cortar JSONs válidos.
LLM_MAX_OUTPUT_TOKENS=256
# Emergencial: desliga cache de chunks/pathfinder e reduz ações. Deixe false para ações completas.
LOW_MEMORY_MODE=false
# Opcional: ligue se quiser limitar cache de chunks em máquinas com pouca RAM.
PRUNE_WORLD_CACHE=false

# ─── Servidor Minecraft ───────────────────────────────────
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
BOT_AUTH=offline
MINECRAFT_VERSION=1.21.11
MINECRAFT_VIEW_DISTANCE=far
MINECRAFT_CHUNK_CACHE_RADIUS=12

# ─── Coleta de Métricas (opcional) ────────────────────────
# Configure para enviar dados de cada ciclo para Supabase.
# Se não configurar, o bot funciona normalmente sem coletar dados.
#
# 1. Crie um projeto em https://supabase.com
# 2. Execute o SQL de supabase/schema.sql no SQL Editor
# 3. Copie a URL e anon key das Settings > API
# SUPABASE_URL=https://SEU-PROJETO.supabase.co
# SUPABASE_ANON_KEY=eyJ...sua-anon-key-aqui
# SUPABASE_TABLE=bot_cycles
